{
  "name": "@data-engine/root",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "eslint packages/*/src/**/*.ts packages/ui/**/*.ts packages/ui/**/*.vue",
    "lint:fix": "eslint --fix packages/*/src/**/*.ts packages/ui/**/*.ts packages/ui/**/*.vue",
    "format": "prettier --write \"packages/*/src/**/*.ts\" \"packages/ui/**/*.{ts,vue}\"",
    "typecheck": "tsc --noEmit",
    "build": "pnpm --filter @data-engine/schema run build && pnpm --filter @data-engine/adapter run build && pnpm --filter @data-engine/adapter-knex run build && pnpm --filter @data-engine/api run build && pnpm --filter @data-engine/migration run build && pnpm --filter @data-engine/engine run build",
    "verify": "pnpm run build && pnpm run typecheck",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/better-sqlite3": "^7.6.13",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "better-sqlite3": "^12.6.2",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "knex": "^3.1.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "vue-eslint-parser": "^10.4.0"
  }
}